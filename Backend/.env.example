# Server Configuration
PORT=3000
JWT_SECRET=your_jwt_secret_here

# Database Configuration (Supabase PostgreSQL Connection URL)
DATABASE_URL=postgresql://postgres:[password]@db.[supabase-ref].supabase.co:5432/postgres

# Email Configuration (Nodemailer Gmail SMTP with App Passwords)
EMAIL_USER=your_gmail_address_here@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Gemini AI Service Configuration
GEMINI_API_KEY=your_gemini_api_key_here
